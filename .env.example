# Cloudflare Access (set via dashboard or wrangler secret put)
TEAM_DOMAIN=https://your-team.cloudflareaccess.com
POLICY_AUD=your-access-aud-tag

# Owner identity (wrangler.jsonc vars)
# OWNER_EMAIL binds Telegram + scheduled traffic to your agent instance.
# ALLOWED_EMAIL_SENDERS is a comma-separated allowlist for inbound email
# (OWNER_EMAIL is always allowed).
OWNER_EMAIL=you@example.com
ALLOWED_EMAIL_SENDERS=

# Email reply routing (optional, set via wrangler secret put)
# HMAC secret for createSecureReplyEmailResolver — lets replies to
# agent-sent email route back to the right instance.
EMAIL_SIGNING_SECRET=

# Web Push (optional, set via wrangler secret put)
# Generate with: npx web-push generate-vapid-keys
# Without these, the "Enable push" button is a no-op (reminders still fire
# in-app and via Telegram/email).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Telegram (set via wrangler secret put)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=holston_bot
# Required — Telegram is disabled without it (webhook verification).
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# MCP Server (optional, set via wrangler secret put)
MCP_SERVER_URL=
