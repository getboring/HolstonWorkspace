{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./src/server.ts",
  "name": "holston-workspace",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    // Assets are served BEFORE the Worker by default, which would bypass the
    // Cloudflare Access gate in fetch(). These routes must hit the Worker first.
    "run_worker_first": ["/", "/index.html"]
  },
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "HolstonAgent",
        "name": "HolstonAgent"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["HolstonAgent"],
      "tag": "v1"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "r2_buckets": [
    {
      "binding": "SKILLS_BUCKET",
      "bucket_name": "holston-skills"
    }
  ],
  "vectorize": [
    {
      "binding": "SKILLS_INDEX",
      "index_name": "holston-skills-v1"
    }
  ],
  // Code execution: Codemode runs LLM-generated code in an isolated Worker via
  // WorkerLoader. Powers the `execute` tool (state.* workspace, cdp.* browser).
  "worker_loaders": [{ "binding": "LOADER" }],
  // Headless browser for the execute tool's cdp.* connectors (navigate,
  // screenshot, extract). Cloudflare Browser Rendering.
  "browser": { "binding": "BROWSER" },
  // Outbound email (agent replies / notifications). Requires a verified
  // sender in Cloudflare Email Routing. Uncomment once configured.
  // "send_email": [{ "name": "EMAIL", "destination_address": "you@example.com" }],
  "vars": {
    "TEAM_DOMAIN": "",
    "POLICY_AUD": "",
    "MCP_SERVER_URL": "",
    "OWNER_EMAIL": "",
    "ALLOWED_EMAIL_SENDERS": ""
  }
  // Secrets (set via `wrangler secret put`): EMAIL_SIGNING_SECRET,
  // VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT,
  // TELEGRAM_BOT_TOKEN, TELEGRAM_BOT_USERNAME, TELEGRAM_WEBHOOK_SECRET_TOKEN.
}